	<object type="tree" name="root">
		<transblock>
			<translate x="0" y="0" z="-2"/>
			<object type="tree">

                
                <transblock>
                    <translate x="0" y="1" z="0"/>
                    <object type="primitive" name="mesh" meshfile ="triangles">
                        <diffuse r=".3" g=".3" b="1"/>
                    </object>
                </transblock>


			</object>
		</transblock>
	</object>

</scenefile>

