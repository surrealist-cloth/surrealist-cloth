<scenefile>
	<globaldata>
		<diffusecoeff v="0.5"/>
		<specularcoeff v="0.5"/>
		<ambientcoeff v="0.5"/>
	</globaldata>

	<cameradata>
		<pos x="0" y="5" z="5"/>
		<focus x="0" y="0" z="0"/>
		<up x="0" y="1" z="0"/>
