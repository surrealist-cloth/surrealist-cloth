<scenefile>
	<globaldata>
		<diffusecoeff v="0.5"/>
		<specularcoeff v="0.5"/>
		<ambientcoeff v="0.5"/>
	</globaldata>

	<cameradata>
		<pos x="-4" y="1" z="3"/>
		<up x="0" y="1" z="0"/>
		<focus x="0" y="0" z="0"/>
		<heightangle v="30"/>
	</cameradata>

	<lightdata>
		<id v="1"/>
		<color r="1" g="1" b="1"/>
		<position x="-4" y="2" z="3"/>
	</lightdata>

	<object type="tree" name="root">
		<transblock>
			<translate x="0" y="-0.6" z="0"/>
			<scale x="6" y="0.2" z="6"/>
			<object type="primitive" name="cube" >
				<diffuse r="1" g="1" b="1"/>
				<specular r="0.5" g="0.5" b="0.5"/>
			</object>
		</transblock>

		<transblock>
			<translate x="-0.8" y="0.2" z="-0.8"/>
			<object type="primitive" name="sphere" >
				<material type="metal"/>
				<ambient r="0" g="1" b="0"/>
				<diffuse r="0.7" g="0.7" b="0.7"/>
				<reflective r="0.8" g="0.8" b="0.8"/>
				<roughness v="0.02"/>
			</object>
		</transblock>

		<transblock>
			<translate x="2" y="-0.2" z="0"/>
			<object type="primitive" name="sphere" >
				<material type="phong"/>
				<reflective r="0.3" g="0.3" b="0.3"/>
				<diffuse r="0" g="1" b="0"/>
				<blend v="0.8"/>
				<shininess v="20"/>
				<specular r="0.2" g="0.2" b="0.2"/>
			</object>
		</transblock>

		<transblock>
			<translate x="0.8" y="-0.2" z="-0.8"/>
			<object type="primitive" name="sphere" >
				<material type="phong"/>
				<reflective r="0.3" g="0.3" b="0.3"/>
				<diffuse r="0" g="0" b="1"/>
				<blend v="0.8"/>
				<shininess v="20"/>
				<specular r="0" g="0" b="0"/>
			</object>
		</transblock>

	</object>

</scenefile>
