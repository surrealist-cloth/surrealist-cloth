<scenefile>
	<globaldata>
		<diffusecoeff v="0.5"/>
		<specularcoeff v="0.5"/>
		<ambientcoeff v="0.5"/>
	</globaldata>

	<cameradata>
		<pos x="0" y="0" z="10"/>
		<look x="0" y="0" z="-1"/>
		<up x="0" y="1" z="0"/>
		<heightangle v="45"/>
	</cameradata>

	<lightdata>
		<id v="1"/>
		<position x="0" y="0" z="0"/>
		<color r="1" g="1" b="1"/>
	</lightdata>

	<object type="tree" name="root">
		<transblock>
			<translate x="0" y="0" z="-2"/>
			<object type="tree">
                
				<transblock>
					<rotate x="0" y="0" z="1" angle="0"/>
					<object type="primitive" name="cone" >
						<diffuse r="1" g="1" b="1"/>
					</object>
				</transblock>
            
                
                
			</object>
		</transblock>
	</object>

</scenefile>

