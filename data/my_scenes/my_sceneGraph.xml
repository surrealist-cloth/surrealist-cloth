<scenefile>
    <globaldata>
        <diffusecoeff v="0.5"/>
        <specularcoeff v="0.5"/>
        <ambientcoeff v="0.5"/>
    </globaldata>

    <lightdata>
        <id v="0"/>
        <color r="1" g="1" b="1"/>
        <position x="4" y="4" z="4"/>
    </lightdata>

    
    <object type="tree" name="root">
        
        <transblock>
            
            <rotate x="1" y="0" z="0" angle="-90"/>
            <object type="tree">
                <!-- tree children-->
                
                
                <transblock>
                    <translate x="-5" y="0" z="0" />
                    <object type="tree">
                        <!-- tree children-->
                        <transblock>
                            <translate x="0" y="-1" z="0" />
                            <rotate x="0" y="0" z="1" angle="-90"/>
                            <scale x="1" y="10" z="10" />
                            <object type="primitive" name="cube" >
                            </object>
                        </transblock>
                        
                        <transblock>
                            <translate x="0" y="1" z="0" />
                            <scale x="2" y="2" z="2" />
                            <object type="primitive" name="sphere" >
                            </object>
                        </transblock>
                        
                    </object>
                </transblock>
                
                

                <transblock>
                    <translate x="0" y="1" z="0" />
                    <object type="primitive" name="cone">
                        <diffuse r="0" g="1" b="0"/>
                    </object>
                </transblock>
                
                
                
            </object> <!-- rotate x, -45 deg. tree ends-->
        </transblock>
        
    </object>

</scenefile>

